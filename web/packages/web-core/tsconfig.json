{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "types": ["vite/client"],
    "baseUrl": ".",
    "paths": {
      "@vibetown/web-core/*": ["./src/*"],
      "@vibetown/ui/*": ["../ui/src/*"]
    }
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}
